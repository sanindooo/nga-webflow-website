{
  "name": "figma-to-webflow-pipeline",
  "version": "0.1.0",
  "description": "Automated Figma-to-Webflow pipeline with Claude Code, MCP, and Playwright visual testing",
  "scripts": {
    "test": "npx playwright test",
    "test:capture": "npx playwright test --grep 'capture'",
    "test:regression": "npx playwright test --grep 'regression'",
    "test:update-baseline": "npx playwright test --update-snapshots",
    "setup": "npx playwright install chromium",
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "dev": "npx http-server scripts/ -p 3000 --cors -c-1",
    "export-assets": "node scripts/api/figma/export-assets.js",
    "upload-assets": "node scripts/api/webflow/upload-assets.js",
    "update-metadata": "node scripts/api/webflow/update-metadata.js",
    "extract-styles": "node scripts/api/figma/extract-styles.js",
    "update-seo": "node scripts/api/webflow/update-seo.js",
    "parse-copy": "node scripts/api/webflow/parse-copy.js"
  },
  "keywords": [
    "webflow",
    "figma",
    "mcp",
    "claude-code",
    "automation",
    "playwright"
  ],
  "license": "MIT",
  "dependencies": {
    "mammoth": "^1.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.4",
    "http-server": "^14.1.1",
    "typescript": "^5.9.3"
  }
}
